{
  "name": "pehenavas-store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite --open --port 3000",
    "server": "node server.js",
    "dev:full": "node server.js & vite --open --port 3000",
    "build": "vite build",
    "postinstall": "npm run build",
    "clean": "rm -rf node_modules package-lock.json dist && npm install",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node scripts/run-tests.js",
    "coverage": "vitest run --coverage",
    "cypress:open": "cypress open",
    "test:all": "npm run lint && npm run build && npx vitest run --coverage && npx start-server-and-test 'npm run dev' http://localhost:3000 'npx cypress run'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.27",
    "cypress": "^15.14.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  }
}
