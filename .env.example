VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Backend server URL (default http://localhost:4000)
VITE_API_URL=http://localhost:3001/api

# Razorpay key (get from dashboard.razorpay.com)
VITE_RAZORPAY_KEY_ID=

# Server-side Firebase admin user (create in Firebase Console > Authentication > Add user)
FIREBASE_ADMIN_EMAIL=admin@example.com
FIREBASE_ADMIN_PASSWORD=your-admin-password

# Firebase Admin SDK service account (base64-encoded JSON key)
# Generate with: base64 -i pehenavas-db-firebase-adminsdk-*.json
FIREBASE_SERVICE_ACCOUNT_B64=
